# ── Cassandra CloudSec Agent — Ortam Değişkenleri Şablonu ──────────────────
# Bu dosyayı kopyala: cp .env.example .env.dev
# Ardından kendi değerlerini gir.

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=loglens
POSTGRES_PASSWORD=loglens_dev
POSTGRES_DB=loglens

# ── Backend ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://loglens:loglens_dev@postgres:5432/loglens
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

DEBUG=true
ENVIRONMENT=development
CORS_ORIGINS=["http://localhost:3000","http://frontend:3000"]

# ── AWS S3 (geliştirmede boş bırakılabilir — lokal depolama kullanılır) ───────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-west-1
S3_BUCKET_NAME=loglens-dev-uploads

# ── Anthropic / LLM API (ZORUNLU) ─────────────────────────────────────────────
# Anthropic API anahtarı: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx
# Özel proxy kullanıyorsan aşağıyı doldur, yoksa boş bırak
ANTHROPIC_BASE_URL=
LLM_MODEL=claude-sonnet-4-5

# ── Clerk Kimlik Doğrulama (isteğe bağlı — Clerk hesabı gerekir) ──────────────
# https://clerk.com → proje oluştur → API Keys
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

# ── Sentry Hata Takibi (isteğe bağlı) ────────────────────────────────────────
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
INTERNAL_API_URL=http://backend:8000

NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard